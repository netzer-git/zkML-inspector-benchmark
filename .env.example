# Copy this file to .env (which is gitignored) and fill in the keys.
# Only needed when running the grader with --backend llm-judge.

# Which provider to use. Options: openai, anthropic.
LLM_PROVIDER=openai

# OpenAI (default provider).
# GPT-4o is required for strict JSON Schema response_format.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (used when LLM_PROVIDER=anthropic).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5
